<odoo>
    <template id="fleet_monthly_template">
        <t t-call="web.basic_layout">
            <t t-foreach="docs" t-as="o">
                <t t-set="month" t-value="dict(o._fields['month'].selection).get(o.month).capitalize()"/>
                <t t-set="partner_ids" t-value="o.partner_ids"/>
                <t t-if="not partner_ids">
                    <t t-set="partner_ids" t-value="[]"/>
                    <t t-foreach="o.odometer_ids" t-as="odometer">
                        <t t-if="odometer.driver_id not in partner_ids">
                            <t t-set="partner_ids" t-value="partner_ids + [odometer.driver_id]"/>
                        </t>
                    </t>
                </t>
                <t t-foreach="partner_ids" t-as="partner">
                    <t t-set="odometer_ids_filter" t-value="sorted(o.odometer_ids.filtered(lambda o: o.driver_id.id == partner.id), key=lambda odometer: (odometer.date, odometer.vehicle_id.license_plate, odometer.start))"/>
                    <t t-set="unique_units" t-value="list(set(dict(odometer.vehicle_id._fields['odometer_unit'].selection).get(odometer.unit) for odometer in odometer_ids_filter))"/>
                    <div class="page" style="page-break-after: always;">
                        <div class="text-center">
                            <h3>Monthly Report</h3>
                        </div>
                        <div class="row mb-3 d-flex justify-content-around text-center">
                            <div class="col-4" style="font-size: 26px;">
                                <t t-esc="partner.name"/>
                            </div>
                            <div class="col-4" style="font-size: 26px;">
                                <t t-esc="month"/>
                            </div>
                            <div class="col-4" t-if="len(unique_units) == 1" style="font-size: 26px;">
                                <t>Unit: </t><t t-esc="unique_units[0]"/>
                            </div>
                        </div>
                        <table style="width: 100%; border-collapse: collapse; border: 1px solid black;">
                            <thead style="border: 2px solid black; background-color: lightgray;">
                                <tr>
                                    <th style="border: 1px solid black; text-align: center; padding: 5px;">DAY</th>
                                    <th style="border: 1px solid black; text-align: center; padding: 5px;">LICENSE PLATE</th>
                                    <th style="border: 1px solid black; text-align: center; padding: 5px;">INITIAL</th>
                                    <th style="border: 1px solid black; text-align: center; padding: 5px;">FINAL</th>
                                    <th style="border: 1px solid black; text-align: center; padding: 5px;" t-if="len(unique_units) > 1">UNIT</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="odometer_ids_filter" t-as="odometer">
                                    <tr style="page-break-inside: avoid; border: 1px solid black;">
                                        <td style="text-align: center; border: 1px solid black; padding: 5px;">
                                            <span t-field="odometer.date"/>
                                        </td>
                                        <td style="text-align: center; border: 1px solid black; padding: 5px;">
                                            <span t-field="odometer.vehicle_id.license_plate"/>
                                        </td>
                                        <td style="text-align: right; border: 1px solid black; padding: 5px;">
                                            <span t-field="odometer.start" t-options="{'widget': 'float', 'precision': 2}"/> 
                                        </td>
                                        <td style="text-align: right; border: 1px solid black; padding: 5px;">
                                            <span t-field="odometer.value" t-options="{'widget': 'float', 'precision': 2}"/> 
                                        </td>
                                        <td style="text-align: center; border: 1px solid black; padding: 5px;" t-if="len(unique_units) > 1">
                                            <span t-field="odometer.unit"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
